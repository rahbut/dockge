{
    "name": "dockge",
    "version": "1.6.0",
    "type": "module",
    "engines": {
        "node": ">= 24.0.0"
    },
    "scripts": {
        "fmt": "eslint --fix .",
        "lint": "eslint .",
        "check-ts": "tsc --noEmit",
        "start": "tsx ./backend/index.ts",
        "dev": "concurrently -k -r \"wait-on tcp:5000 && npm run dev:backend \" \"npm run dev:frontend\"",
        "dev:backend": "cross-env NODE_ENV=development tsx watch --inspect ./backend/index.ts",
        "dev:frontend": "cross-env NODE_ENV=development vite --host --config ./frontend/vite.config.ts",
        "release-final": "tsx ./extra/test-docker.ts && tsx extra/update-version.ts && npm run build:frontend && npm run build:docker",
        "build:frontend": "vite build --config ./frontend/vite.config.ts",
        "build:docker-base": "docker buildx build --platform linux/amd64,linux/arm64 -t ghcr.io/rahbut/dockge:base --target base -f ./docker/Dockerfile . --push",
        "build:docker": "node ./extra/env2arg.js docker buildx build --platform linux/amd64,linux/arm64 -t ghcr.io/rahbut/dockge:latest -t ghcr.io/rahbut/dockge:$VERSION --target release -f ./docker/Dockerfile . --push",
        "build:healthcheck": "docker buildx build -f docker/BuildHealthCheck.Dockerfile --platform linux/amd64,linux/arm64 -t ghcr.io/rahbut/dockge:build-healthcheck . --push",
        "start-docker": "docker run --rm -p 5001:5001 --name dockge ghcr.io/rahbut/dockge:latest",
        "reformat-changelog": "tsx ./extra/reformat-changelog.ts",
        "reset-password": "tsx ./extra/reset-password.ts"
    },
    "dependencies": {
        "node-pty": "~1.1.0",
        "@inventage/envsubst": "^0.16.0",
        "better-sqlite3": "~12.8.0",
        "bcryptjs": "~2.4.3",
        "check-password-strength": "~2.0.10",
        "command-exists": "~1.2.9",
        "compare-versions": "~6.1.1",
        "composerize": "~1.7.1",
        "croner": "~8.1.2",
        "dayjs": "~1.11.13",
        "dotenv": "~16.3.2",
        "express": "~4.22.1",
        "express-static-gzip": "~2.1.8",
        "http-graceful-shutdown": "~3.1.14",
        "jsonwebtoken": "~9.0.2",
        "jwt-decode": "~3.1.2",
        "knex": "~2.5.1",
        "limiter-es6-compat": "~2.1.2",
        "mysql2": "~3.12.0",
        "promisify-child-process": "~4.1.2",
        "redbean-node": "~0.3.3",
        "semver": "^7.7.1",
        "socket.io": "~4.8.3",
        "socket.io-client": "~4.8.3",
        "timezones-list": "~3.0.3",
        "ts-command-line-args": "~2.5.1",
        "tsx": "~4.19.3",
        "type-fest": "~4.3.3",
        "yaml": "~2.3.4"
    },
    "devDependencies": {
        "@actions/github": "^9.0.0",
        "@codemirror/lang-python": "^6.1.7",
        "@codemirror/lang-yaml": "^6.1.2",
        "@fontsource/jetbrains-mono": "^5.2.5",
        "@fortawesome/fontawesome-svg-core": "6.4.2",
        "@fortawesome/free-regular-svg-icons": "6.4.2",
        "@fortawesome/free-solid-svg-icons": "6.4.2",
        "@fortawesome/vue-fontawesome": "3.0.3",
        "@types/bcryptjs": "^2.4.6",
        "@types/bootstrap": "~5.2.10",
        "@types/command-exists": "~1.2.3",
        "@types/express": "~4.17.21",
        "@types/jsonwebtoken": "~9.0.9",
        "@types/semver": "^7.7.0",
        "@eslint/js": "^9.0.0",
        "@vitejs/plugin-vue": "~5.2.3",
        "@xterm/addon-fit": "beta",
        "@xterm/xterm": "beta",
        "bootstrap": "5.3.2",
        "bootstrap-vue-next": "~0.14.10",
        "codemirror": "^6.0.1",
        "concurrently": "^8.2.2",
        "cross-env": "~7.0.3",
        "eslint": "^9.0.0",
        "eslint-plugin-jsdoc": "^50.0.0",
        "eslint-plugin-vue": "^9.32.0",
        "globals": "^15.0.0",
        "sass": "~1.99.0",
        "thememirror": "^2.0.1",
        "typescript": "~5.2.2",
        "unplugin-vue-components": "~0.25.2",
        "vite": "~5.4.21",
        "vite-plugin-compression": "~0.5.1",
        "vue": "~3.5.13",
        "vue-codemirror6": "^1.3.13",
        "typescript-eslint": "^8.0.0",
        "vue-i18n": "^11.0.0",
        "vue-qrcode": "~2.2.2",
        "vue-router": "~4.5.0",
        "vue-toastification": "2.0.0-rc.5",
        "wait-on": "~9.0.4",
        "@stylistic/eslint-plugin": "^4.0.0"
    },
    "overrides": {
        "jws": ">=3.2.3",
        "tar-fs": ">=2.1.4",
        "picomatch": ">=2.3.2",
        "minimatch": ">=3.1.4",
        "lodash": ">=4.17.24",
        "glob": ">=10.4.6",
        "flatted": ">=3.3.3"
    }
}
